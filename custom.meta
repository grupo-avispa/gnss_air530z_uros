{
    "names": {
        "rmw_microxrcedds": {
            "cmake-args": [
                "-DRMW_UXRCE_MAX_NODES=2",
                "-DRMW_UXRCE_MAX_PUBLISHERS=6",
                "-DRMW_UXRCE_MAX_SUBSCRIPTIONS=2",
                "-DRMW_UXRCE_MAX_SERVICES=0",
                "-DRMW_UXRCE_MAX_CLIENTS=0",
                "-DRMW_UXRCE_MAX_HISTORY=8",
                "-DRMW_UXRCE_STREAM_HISTORY=8",
                "-DRMW_UXRCE_TRANSPORT=custom",
                "-DRMW_UXRCE_MAX_TRANSPORT_MTU=2048"
            ]
        },
        "microxrcedds_client":{
                "cmake-args": [
                    "-DUCLIENT_UDP_TRANSPORT_MTU=2048",
                    "-DUCLIENT_CUSTOM_TRANSPORT_MTU=2048"
                ]
        }
    }
}